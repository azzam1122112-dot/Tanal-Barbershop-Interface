generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  SUPERVISOR
  BARBER
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentMethod {
  CASH
  NETWORK
}

enum VisitStatus {
  COMPLETED
  CANCELLED
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum DiscountType {
  NONE
  REWARD
  CAMPAIGN
  MANAGER_REWARD
}

enum CampaignDiscountType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum CampaignTargetType {
  ALL_CUSTOMERS
  NEW_CUSTOMERS
  INACTIVE_CUSTOMERS
  CUSTOMERS_WITH_MIN_POINTS
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  ADJUST
  EXPIRE
  REVERSAL
}

enum AuditActorType {
  PLATFORM_ADMIN
  OWNER
  ADMIN
  SUPERVISOR
  BARBER
  SYSTEM
}

enum WhatsAppTemplateType {
  POST_VISIT
  REWARD_READY
  CAMPAIGN
  INACTIVE_CUSTOMER
  CUSTOM
}

enum WhatsAppMessageStatus {
  DRAFTED
  OPENED
  MARKED_SENT
  SKIPPED
  FAILED
}

// ===== Platform / Tenancy =====

// مدير المنصة (super-admin) — يدير كل المؤسسات والباقات. خارج أي مستأجر.
model PlatformAdmin {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

// الباقة — يضبطها السوبر-آدمن من لوحة المنصة (بلا بوابة دفع حاليًا).
model Plan {
  id            String         @id @default(cuid())
  name          String         @unique
  slug          String         @unique
  description   String?
  priceMonthly  Decimal        @default(0) @db.Decimal(10, 2)
  maxSalons     Int            @default(1)
  maxBarbers    Int? // null = غير محدود
  maxCustomers  Int?
  isActive      Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  organizations Organization[]

  @@index([isActive, sortOrder])
}

// المؤسسة (المالك) — حدّ العزل الأساسي + العميل/الولاء + الفوترة.
model Organization {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique // النطاق الفرعي
  status             OrganizationStatus @default(ACTIVE)
  planId             String?
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  plan                 Plan?                @relation(fields: [planId], references: [id])
  salons               Salon[]
  users                User[]
  barbers              Barber[]
  customers            Customer[]
  services             Service[]
  visits               Visit[]
  loyaltyAccounts      LoyaltyAccount[]
  loyaltyTransactions  LoyaltyTransaction[]
  rewardRules          RewardRule[]
  campaigns            Campaign[]
  campaignRedemptions  CampaignRedemption[]
  managerRewards       ManagerReward[]
  dailyCloses          DailyClose[]
  cashSessions         CashSession[]
  systemSettings       SystemSettings[]
  whatsappTemplates    WhatsAppTemplate[]
  whatsappMessages     WhatsAppMessageLog[]
  auditLogs            AuditLog[]
  sessions             Session[]

  @@index([status])
  @@index([planId])
}

// الصالون — الوحدة التشغيلية داخل المؤسسة.
model Salon {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  barbers      Barber[]
  services     Service[]
  visits       Visit[]
  cashSessions CashSession[]
  dailyCloses  DailyClose[]
  settings     SystemSettings?
  sessions     Session[]

  @@unique([organizationId, slug])
  @@index([organizationId, isActive])
}

// ===== Tenant data =====

model User {
  id                         String               @id @default(cuid())
  organizationId             String?
  name                       String
  email                      String?
  phone                      String
  passwordHash               String
  role                       UserRole             @default(ADMIN)
  isActive                   Boolean              @default(true)
  lastLoginAt                DateTime?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  organization               Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditLogs                  AuditLog[]
  sessions                   Session[]
  dailyCloses                DailyClose[]         @relation("DailyCloseReceivedBy")
  closedCashSessions         CashSession[]        @relation("CashSessionClosedBy")
  cancelledVisits            Visit[]              @relation("VisitCancelledBy")
  openedWhatsAppMessages     WhatsAppMessageLog[] @relation("WhatsAppOpenedBy")
  markedSentWhatsAppMessages WhatsAppMessageLog[] @relation("WhatsAppMarkedSentBy")
  issuedManagerRewards       ManagerReward[]      @relation("ManagerRewardIssuedBy")

  @@unique([organizationId, email])
  @@unique([organizationId, phone])
  @@index([organizationId, role, isActive])
}

model Barber {
  id               String        @id @default(cuid())
  organizationId   String?
  salonId          String?
  name             String
  phone            String
  accessPinHash    String
  role             UserRole      @default(BARBER)
  isActive         Boolean       @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon            Salon?        @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdCustomers Customer[]    @relation("CustomerCreatedByBarber")
  visits           Visit[]
  auditLogs        AuditLog[]    @relation("BarberAuditLogs")
  sessions         Session[]
  dailyCloses      DailyClose[]
  cashSessions     CashSession[]

  @@unique([salonId, phone])
  @@index([salonId, isActive])
  @@index([organizationId])
}

model Session {
  id             String         @id @default(cuid())
  tokenHash      String         @unique
  actorType      AuditActorType
  organizationId String?
  activeSalonId  String?
  userId         String?
  barberId        String?
  platformAdminId String?
  role            UserRole?
  createdAt       DateTime       @default(now())
  expiresAt       DateTime
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  userAgent       String?
  ipAddress       String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  barber          Barber?        @relation(fields: [barberId], references: [id], onDelete: Cascade)
  organization    Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activeSalon     Salon?         @relation(fields: [activeSalonId], references: [id], onDelete: SetNull)
  platformAdmin   PlatformAdmin? @relation(fields: [platformAdminId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId, revokedAt])
  @@index([barberId, revokedAt])
  @@index([expiresAt])
  @@index([organizationId])
  @@index([platformAdminId])
}

model Customer {
  id                  String               @id @default(cuid())
  organizationId      String?
  name                String
  phone               String
  whatsappOptIn       Boolean              @default(true)
  visitCount          Int                  @default(0)
  totalPaid           Decimal              @default(0) @db.Decimal(12, 2)
  lastVisitAt         DateTime?
  lastBarberId        String?
  createdByBarberId   String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organization        Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByBarber     Barber?              @relation("CustomerCreatedByBarber", fields: [createdByBarberId], references: [id])
  visits              Visit[]
  loyaltyAccount      LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[]
  campaignRedemptions CampaignRedemption[]
  managerRewards      ManagerReward[]
  whatsappMessages    WhatsAppMessageLog[]

  @@unique([organizationId, phone])
  @@index([organizationId, lastVisitAt])
  @@index([organizationId, whatsappOptIn])
  @@index([createdByBarberId])
}

model Service {
  id             String         @id @default(cuid())
  organizationId String?
  salonId        String?
  name           String
  defaultPrice   Decimal        @db.Decimal(10, 2)
  isActive       Boolean        @default(true)
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon          Salon?         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  visitServices  VisitService[]

  @@unique([salonId, name])
  @@index([salonId, isActive, sortOrder])
  @@index([organizationId])
}

model Visit {
  id                  String               @id @default(cuid())
  organizationId      String?
  salonId             String?
  customerId          String
  barberId            String
  status              VisitStatus          @default(COMPLETED)
  grossAmount         Decimal              @db.Decimal(10, 2)
  discountAmount      Decimal              @default(0) @db.Decimal(10, 2)
  netAmount           Decimal              @db.Decimal(10, 2)
  paymentMethod       PaymentMethod
  discountType        DiscountType         @default(NONE)
  discountSourceId    String?
  idempotencyKey      String?
  pointsEarned        Int                  @default(0)
  notes               String?
  closedAt            DateTime?
  cancelledAt         DateTime?
  cancelledByUserId   String?
  cancelReason        String?
  visitedAt           DateTime             @default(now())
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organization        Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon               Salon?               @relation(fields: [salonId], references: [id], onDelete: Cascade)
  customer            Customer             @relation(fields: [customerId], references: [id])
  barber              Barber               @relation(fields: [barberId], references: [id])
  services            VisitService[]
  loyaltyTransactions LoyaltyTransaction[]
  campaignRedemption  CampaignRedemption?
  managerReward       ManagerReward?
  cancelledBy         User?                @relation("VisitCancelledBy", fields: [cancelledByUserId], references: [id])
  cashSessionId       String?
  cashSession         CashSession?         @relation(fields: [cashSessionId], references: [id])
  whatsappMessages    WhatsAppMessageLog[]

  @@unique([barberId, idempotencyKey])
  @@index([organizationId, visitedAt])
  @@index([salonId, visitedAt])
  @@index([visitedAt])
  @@index([barberId, visitedAt])
  @@index([customerId, visitedAt])
  @@index([status])
  @@index([cancelledByUserId])
  @@index([cashSessionId])
}

model VisitService {
  id          String  @id @default(cuid())
  visitId     String
  serviceId   String
  serviceName String
  unitPrice   Decimal @db.Decimal(10, 2)
  quantity    Int     @default(1)
  lineTotal   Decimal @db.Decimal(10, 2)
  visit       Visit   @relation(fields: [visitId], references: [id], onDelete: Cascade)
  service     Service @relation(fields: [serviceId], references: [id])

  @@index([visitId])
  @@index([serviceId])
}

model LoyaltyAccount {
  id               String        @id @default(cuid())
  organizationId   String?
  customerId       String        @unique
  points           Int           @default(0)
  lifetimeEarned   Int           @default(0)
  lifetimeRedeemed Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer         Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId, points])
}

model LoyaltyTransaction {
  id             String                 @id @default(cuid())
  organizationId String?
  customerId     String
  visitId        String?
  type           LoyaltyTransactionType
  points         Int
  balanceAfter   Int
  description    String?
  createdAt      DateTime               @default(now())
  organization   Organization?          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer               @relation(fields: [customerId], references: [id])
  visit          Visit?                 @relation(fields: [visitId], references: [id])

  @@index([customerId, createdAt])
  @@index([visitId])
  @@index([type])
  @@index([organizationId])
}

model RewardRule {
  id             String        @id @default(cuid())
  organizationId String?
  name           String
  requiredPoints Int
  discountAmount Decimal       @db.Decimal(10, 2)
  isActive       Boolean       @default(true)
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@unique([organizationId, requiredPoints])
  @@index([organizationId, isActive, requiredPoints])
}

model Campaign {
  id                 String               @id @default(cuid())
  organizationId     String?
  name               String
  description        String?
  discountType       CampaignDiscountType
  discountValue      Decimal              @db.Decimal(10, 2)
  targetType         CampaignTargetType
  inactiveDays       Int?
  minPoints          Int?
  startAt            DateTime
  endAt              DateTime
  maxUsesPerCustomer Int                  @default(1)
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  organization       Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  redemptions        CampaignRedemption[]
  whatsappMessages   WhatsAppMessageLog[]

  @@index([organizationId, isActive, startAt, endAt])
  @@index([targetType])
}

model CampaignRedemption {
  id             String        @id @default(cuid())
  organizationId String?
  campaignId     String
  customerId     String
  visitId        String        @unique
  discountAmount Decimal       @db.Decimal(10, 2)
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign       Campaign      @relation(fields: [campaignId], references: [id])
  customer       Customer      @relation(fields: [customerId], references: [id])
  visit          Visit         @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([campaignId, customerId])
  @@index([customerId, createdAt])
  @@index([organizationId])
}

model ManagerReward {
  id              String        @id @default(cuid())
  organizationId  String?
  customerId      String
  issuedByUserId  String
  redeemedVisitId String?       @unique
  title           String
  description     String?
  discountAmount  Decimal       @db.Decimal(10, 2)
  expiresAt       DateTime?
  redeemedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  issuedBy        User          @relation("ManagerRewardIssuedBy", fields: [issuedByUserId], references: [id])
  redeemedVisit   Visit?        @relation(fields: [redeemedVisitId], references: [id])

  @@index([customerId, redeemedAt, revokedAt, expiresAt])
  @@index([issuedByUserId, createdAt])
  @@index([redeemedVisitId])
  @@index([organizationId])
}

model DailyClose {
  id                       String        @id @default(cuid())
  organizationId           String?
  salonId                  String?
  barberId                 String
  date                     DateTime
  visitsCount              Int           @default(0)
  grossTotal               Decimal       @default(0) @db.Decimal(12, 2)
  discountTotal            Decimal       @default(0) @db.Decimal(12, 2)
  netTotal                 Decimal       @default(0) @db.Decimal(12, 2)
  cashTotal                Decimal       @default(0) @db.Decimal(12, 2)
  cardTotal                Decimal       @default(0) @db.Decimal(12, 2)
  pointsEarnedTotal        Int           @default(0)
  pointsRedeemedTotal      Int           @default(0)
  rewardRedemptionsCount   Int           @default(0)
  campaignRedemptionsCount Int           @default(0)
  cashReceivedAmount       Decimal       @default(0) @db.Decimal(12, 2)
  receivedByUserId         String
  receivedAt               DateTime      @default(now())
  notes                    String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  organization             Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon                    Salon?        @relation(fields: [salonId], references: [id], onDelete: Cascade)
  barber                   Barber        @relation(fields: [barberId], references: [id])
  receivedBy               User          @relation("DailyCloseReceivedBy", fields: [receivedByUserId], references: [id])

  @@unique([barberId, date])
  @@index([organizationId, date])
  @@index([salonId, date])
  @@index([date])
  @@index([receivedByUserId])
}

model CashSession {
  id                       String            @id @default(cuid())
  organizationId           String?
  salonId                  String?
  barberId                 String
  status                   CashSessionStatus @default(OPEN)
  openedAt                 DateTime          @default(now())
  closedAt                 DateTime?
  closedByUserId           String?
  visitsCount              Int               @default(0)
  grossTotal               Decimal           @default(0) @db.Decimal(12, 2)
  discountTotal            Decimal           @default(0) @db.Decimal(12, 2)
  netTotal                 Decimal           @default(0) @db.Decimal(12, 2)
  cashTotal                Decimal           @default(0) @db.Decimal(12, 2)
  cardTotal                Decimal           @default(0) @db.Decimal(12, 2)
  pointsEarnedTotal        Int               @default(0)
  pointsRedeemedTotal      Int               @default(0)
  rewardRedemptionsCount   Int               @default(0)
  campaignRedemptionsCount Int               @default(0)
  cashReceivedAmount       Decimal?          @db.Decimal(12, 2)
  notes                    String?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  organization             Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon                    Salon?            @relation(fields: [salonId], references: [id], onDelete: Cascade)
  barber                   Barber            @relation(fields: [barberId], references: [id])
  closedBy                 User?             @relation("CashSessionClosedBy", fields: [closedByUserId], references: [id])
  visits                   Visit[]

  @@index([organizationId, status])
  @@index([salonId, status])
  @@index([barberId, status])
  @@index([openedAt])
  @@index([closedAt])
  @@index([closedByUserId])
}

model SystemSettings {
  id                            String        @id @default(cuid())
  organizationId                String?
  salonId                       String?       @unique
  singletonKey                  String?
  salonName                     String
  currency                      String        @default("SAR")
  pointsPerCurrencyUnit         Decimal       @default(1) @db.Decimal(8, 2)
  pointsCalculatedAfterDiscount Boolean       @default(true)
  allowMultipleDiscounts        Boolean       @default(false)
  whatsappDefaultCountryCode    String        @default("966")
  whatsappEnabled               Boolean       @default(true)
  createdAt                     DateTime      @default(now())
  updatedAt                     DateTime      @updatedAt
  organization                  Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salon                         Salon?        @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model WhatsAppTemplate {
  id             String               @id @default(cuid())
  organizationId String?
  name           String
  type           WhatsAppTemplateType
  body           String
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       WhatsAppMessageLog[]

  @@index([organizationId, type, isActive])
}

model WhatsAppMessageLog {
  id                 String                @id @default(cuid())
  organizationId     String?
  customerId         String
  templateId         String?
  campaignId         String?
  visitId            String?
  phone              String
  message            String
  waUrl              String
  status             WhatsAppMessageStatus @default(DRAFTED)
  openedByUserId     String?
  openedAt           DateTime?
  markedSentByUserId String?
  markedSentAt       DateTime?
  skippedReason      String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  organization       Organization?         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer           Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  template           WhatsAppTemplate?     @relation(fields: [templateId], references: [id])
  campaign           Campaign?             @relation(fields: [campaignId], references: [id])
  visit              Visit?                @relation(fields: [visitId], references: [id])
  openedBy           User?                 @relation("WhatsAppOpenedBy", fields: [openedByUserId], references: [id])
  markedSentBy       User?                 @relation("WhatsAppMarkedSentBy", fields: [markedSentByUserId], references: [id])

  @@index([customerId, createdAt])
  @@index([templateId])
  @@index([campaignId])
  @@index([visitId])
  @@index([status, createdAt])
  @@index([openedByUserId])
  @@index([markedSentByUserId])
  @@index([organizationId])
}

model LoginAttempt {
  id          String    @id @default(cuid())
  key         String    @unique
  count       Int       @default(0)
  windowStart DateTime  @default(now())
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([lockedUntil])
}

model AuditLog {
  id             String         @id @default(cuid())
  organizationId String?
  salonId        String?
  actorType      AuditActorType
  actorUserId    String?
  actorBarberId  String?
  action         String
  entityType     String
  entityId       String?
  before         Json?
  after          Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime       @default(now())
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser      User?          @relation(fields: [actorUserId], references: [id])
  actorBarber    Barber?        @relation("BarberAuditLogs", fields: [actorBarberId], references: [id])

  @@index([createdAt])
  @@index([actorType, createdAt])
  @@index([entityType, entityId])
  @@index([organizationId, createdAt])
}
