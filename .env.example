DATABASE_URL="postgresql://tanal_user:tanal_dev_password@localhost:55432/tanal_loyalty?schema=public"

# Seed credentials for local development only.
REQUIRE_EXPLICIT_SEED_CREDENTIALS="false"
SEED_ADMIN_PHONE="966500000001"
SEED_ADMIN_EMAIL="admin@tanal.local"
SEED_ADMIN_PASSWORD="Admin@12345"
SEED_BARBER_PHONE="966500000002"
SEED_BARBER_PIN="1234"

# Security / operations (optional locally).
# Comma-separated list of trusted browser origins for CSRF Origin checks.
# Same-origin requests are always allowed; set this only for extra origins.
ALLOWED_ORIGINS=""
# Shared secret for the scheduled maintenance cleanup endpoint
# (POST /api/maintenance/cleanup with header x-maintenance-token).
MAINTENANCE_TOKEN=""
# Logging verbosity: debug | info | warn | error.
LOG_LEVEL="debug"

# Production/Render:
# - DATABASE_URL is supplied from Render PostgreSQL.
# - Set REQUIRE_EXPLICIT_SEED_CREDENTIALS="true".
# - Provide real SEED_* values in the Render Dashboard; do not commit them.
# - Set ALLOWED_ORIGINS to your public web URL, and MAINTENANCE_TOKEN to a strong secret.
